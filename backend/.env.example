# LLM Provider Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Portkey (model routing + AIRS guardrail)
PORTKEY_API_KEY=your_portkey_key_here
PORTKEY_AIRS_CONFIG_ID=your_portkey_config_id_here
GROQ_VIRTUAL_KEY=your_groq_virtual_key_from_portkey  # optional: use if you set up Groq virtual key in Portkey
GROQ_API_KEY=your_groq_api_key_here                  # alternative: use direct Groq API key

# Prisma AIRS
PRISMA_AIRS_API_KEY=your_prisma_airs_key_here
PRISMA_AIRS_PROFILE=your_profile_name_here
PRISMA_AIRS_ENDPOINT=https://service.api.aisecurity.paloaltonetworks.com/v1/scan/sync/request
